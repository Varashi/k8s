{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "ignorePaths": [
    "**/vars/cluster-secrets.yaml"
  ],
  "kubernetes": {
    "managerFilePatterns": ["/^cluster-talos/.+\\.ya?ml$/"],
    "ignorePaths": ["cluster-talos/talos/nodes/patches/**"]
  },
  "flux": {
    "managerFilePatterns": ["/^cluster-talos/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Talos installer version in talm values.yaml",
      "managerFilePatterns": ["/^cluster-talos/talos/values\\.yaml$/"],
      "matchStrings": [
        "version:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "Cilium version in bootstrap Makefile",
      "managerFilePatterns": ["/^cluster-talos/talos/Makefile$/"],
      "matchStrings": [
        "--version\\s+(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.cilium.io",
      "depNameTemplate": "cilium"
    },
    {
      "customType": "regex",
      "description": "Pinned ARG versions in custom image Dockerfiles",
      "managerFilePatterns": [
        "/^cluster-talos/kubernetes/apps/.+/image/Dockerfile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>[^\\s]+)(?:\\s+versioning=(?<versioning>[a-z-]+))?\\s*\\nARG\\s+[A-Z0-9_]+=(?<currentValue>[^\\s\"]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["flux"],
      "groupName": "helm charts",
      "automerge": false
    },
    {
      "matchDepNames": ["siderolabs/talos", "cilium"],
      "matchFileNames": ["cluster-talos/**"],
      "groupName": "cluster-talos infra",
      "automerge": false
    },
    {
      "description": "vSphere CSI pins its own sidecar versions; bump as bundle with the driver",
      "matchFileNames": ["cluster-talos/kubernetes/infrastructure/core/vsphere-csi/**"],
      "matchPackageNames": ["registry.k8s.io/sig-storage/**"],
      "enabled": false
    },
    {
      "description": "Split risky major helm bumps into per-chart PRs",
      "matchManagers": ["flux"],
      "matchUpdateTypes": ["major"],
      "matchDepNames": [
        "external-secrets",
        "netbox",
        "prometheus",
        "ghcr.io/varashi/charts/gpu-node-vsphere-maintenance-controller"
      ],
      "groupName": null
    },
    {
      "description": "LSIO images use 4-part tags with git-hash and -lsNNN suffix; default docker versioning can't parse",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/linuxserver/**"],
      "versioning": "loose",
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+(\\.\\d+)?(-[a-z0-9]+)*-ls\\d+$/"
    },
    {
      "description": "Auto-merge home-operations image digest rebuilds",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/home-operations/**"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": false
    },
    {
      "description": "Auto-merge GitHub Actions with 3-day cooldown",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "minimumReleaseAge": "3 days",
      "ignoreTests": true
    },
    {
      "description": "Auto-merge trusted GitHub Actions publishers without cooldown",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["actions/**", "fluxcd/**", "renovatebot/**"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "minimumReleaseAge": "1 minute",
      "ignoreTests": true
    }
  ]
}
