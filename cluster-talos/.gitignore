# OpenTofu
tofu/terraform.tfvars
tofu/.terraform/
tofu/terraform.tfstate
tofu/terraform.tfstate.backup
tofu/.terraform.tfstate.lock.info

# Talos PKI — never commit plaintext; committed copy is secrets.encrypted.yaml
talos/secrets.yaml
talos/talm.key

# Site-specific talm overrides (domain / certSANs) — keep identifying info out of git
talos/values.local.yaml

# Full rendered machine configs (embed PKI) — produced by talm template --full
# Talos rejects partial guestinfo configs (cluster block + CA required), so
# nodes/bootstrap/*.yaml now holds full renders consumed by tofu guestinfo.
# nodes/values/ and nodes/patches/ ARE committed.
talos/nodes/cp-*.yaml
talos/nodes/worker-*.yaml
talos/nodes/bootstrap/*.yaml

# Generated client configs
talos/clusterconfig/

# Flux bootstrap output (generated by flux bootstrap, committed separately)
kubernetes/bootstrap/flux-system/gotk-components.yaml
kubernetes/bootstrap/flux-system/gotk-sync.yaml
